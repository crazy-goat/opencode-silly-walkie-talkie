# Przykładowa konfiguracja zrok dla Dokploy
# Skopiuj ten plik jako .env i uzupełnij wartości

# === KONFIGURACJA DOMEN ===
# Główna domena dla zrok (wszystkie subdomeny muszą wskazywać na VPS)
ZROK_DOMAIN=twojadomena.pl

# Endpoint API controllera (subdomena)
ZROK_API_ENDPOINT=https://api.zrok.twojadomena.pl

# Frontend wildcard (dla tuneli użytkowników)
ZROK_FRONTEND_ENDPOINTS=https://*.zrok.twojadomena.pl

# Główny endpoint frontendu (ładowanie strony z tokenu)
ZROK_FRONTEND_ENDPOINT=https://tunel.zrok.twojadomena.pl

# === BEZPIECZEŃSTWO ===
# Token administratora (zmień na silny hasło!)
ZROK_ADMIN_TOKEN=twój-silny-token-admina-123456

# Token użytkownika (wygenerowany przez `zrok enable`, lub pusty przy pierwszym uruchomieniu)
ZROK_TOKEN=

# === OPCJONALNIE ===
# Email dla Let's Encrypt (jeśli używasz automatycznych certyfikatów)
ZROK_ACME_EMAIL=admin@twojadomena.pl
