{
  "name": "@crazy-goat/opencode-walkie-talkie",
  "version": "0.1.0",
  "description": "Walkie-Talkie plugin for OpenCode - mobile notifications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@opencode-ai/plugin && mkdir -p ../.opencode/plugins && cp dist/index.js ../.opencode/plugins/walkie-talkie.js",
    "dev:serve": "WALKIE_PORT=8765 WALKIE_TOKEN=dev-token opencode serve --print-logs",
    "dev": "tsc --bundle --watch --platform=node --format=esm --outfile=dist/index.js --external:@opencode-ai/plugin",
    "test": "jest"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "walkie-talkie",
    "mobile"
  ],
  "author": "crazy-goat",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.27",
    "@types/qrcode-terminal": "^0.12.2",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.27.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
